---
const links = [
	{
		name: "About",
		href: "/about",
	},
	{
		name: "Resources",
		href: "/resources",
	},
	{
		name: "Impact",
		href: "/impact",
	},
	{
		name: "Apply",
		href: "/apply",
	},
	{
		name: "Team",
		href: "/team",
	},
];
---

<nav>
	<a href="/" class="icon">
		<div class="image"></div>
		<span>Pacific Education Network</span>
	</a>
	<div class="spacer"></div>
	{links.map(x => <a class="page-link" href={x.href}>|{x.name}|</a>)}
</nav>

<style>
	nav {
		display: flex;
		align-items: center;
        gap: var(--fluid-4-20);
	}
	a {
		color: inherit;
		text-decoration: none;
	}
    .page-link {
        font-size: clamp(0.625rem, 0.292rem + 1.6393vw, 1.5625rem);
    }
	.icon {
		display: flex;
		align-items: center;
		gap: var(--space-s);
		.image {
			aspect-ratio: 1 / 1;
			display: flex;
			justify-content: center;
			align-items: center;
            /* temp */
            border-radius: 50%;
            width: var(--step--2);
            height: var(--step--2);
		}
		span {
			font-size: var(--fluid-10-36);
			padding-left: var(--padding);
			padding-bottom: var(--space-xs);
		}
	}
    .spacer {
        flex-grow: 1;
    }

</style>
