---
import Word from "../components/Word.astro";
import Layout from "../layouts/Layout.astro";
import Launch from "../assets/icons/launch.svg";
import { Image } from "astro:assets";
const boardTop = [
	{
		name: "Yicheng Yang",
		title: "Founder & President",
		image: "Yicheng Yang Exec.png",
