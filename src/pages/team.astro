---
import Word from "../components/Word.astro";
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
const boardTop = [
	{
		name: "Yicheng Yang",
		title: "Founder & President",
		image: "Yicheng Yang Exec.png",
	},
	{
		name: "Sam Wang",
		title: "Co-Founder & Vice President",
		image: "Sam Wang Exec.jpeg",
	}
];

const board = [
	{
		name: "Ayden Leung",
		title: "Design Manager",
		image: "Ayden Leung Exec.png",
	},
	{
		name: "Alisa Du",
		title: "Social Media Manager",
		image: "Alisa Du Exec.jpeg",
	},
	{
		name: "Ben Fung",
		title: "Head Tutor",
		image: "Ben Fung Exec.jpg",
	},
	{
		name: "Lucas Moss",
		title: "Web Developer",
		image: "Lucas.jpg",
	},
];

const tutors = [
	{
		subject: "Mathematics",
		members: [
			{ name: "Hyobeen Ahn", title: "Math Tutor", image: "Hyobeen Ahn Tutor.jpg" },
			{ name: "Amir Shekari", title: "Math Tutor", image: "Amir Shekari Tutor.jpeg" },
			{ name: "Lucy Dong", title: "Math Tutor", image: "Lucy Dong.jpeg" },
			{ name: "Anushka Mukherjee", title: "Math & English Tutor", image: "Anushka Mukherjee Tutor.jpeg" },
			{ name: "Meghan Sandhu", title: "Math Tutor", image: "Meghan Sandhu Tutor.png" },
			{ name: "Ethan Fu", title: "Math Tutor", image: "Ethan Fu Math Tutor.jpg" },
		]
	},
	{
		subject: "Sciences",
		members: [
			{ name: "Emad Badei", title: "Biology Tutor", image: "Emad Badei Tutor.jpeg" },
			{ name: "Matt Chong", title: "Physics Tutor", image: "Matt Chong Tutor.jpg" },
			{ name: "Ayesha Klair", title: "Biology Tutor", image: "Ayesha Klair Tutor.jpeg" },
		]
	},
	{
		subject: "Languages",
		members: [
			{ name: "James Lin", title: "English Tutor", image: "James Lin Tutor.JPG" },
			{ name: "Gillian Xie", title: "English Tutor", image: "Gillian Xie Tutor.png" },
			{ name: "Emma Jia", title: "English Tutor", image: "Emma Jia Tutor.jpeg" },
			{ name: "Mike Zhang", title: "English Tutor", image: "Mike Zhang Tutor.jpeg" },
			{ name: "Amy Lu", title: "English Tutor", image: "Amy Lu Tutor.png" },
			{ name: "Chloe Fu", title: "English Tutor", image: "Chloe Fu Tutor.jpg" },
			{ name: "Anushka Mukherjee", title: "Math / English Tutor", image: "Anushka Mukherjee Tutor.jpeg" },
			{ name: "Jahnavi Bhosale", title: "English Tutor", image: "Jahnavi Bhosale English Tutor.jpeg" },
			{ name: "Brianna Barbucci", title: "French Tutor", image: "Brianna Barbucci French Tutor.jpeg" },
		]
	}
];

const images = import.meta.glob<{ default: ImageMetadata }>("../assets/img/team/*", { eager: true });

const imageFor = (name: string) => images[`../assets/img/team/${name}`].default;
---

<Layout title = "PEN | Team">
	<div class="title">
		<Word><h1>Meet Our <em>Dedicated</em> Team</h1></Word>
		<Word delay={1}
			><p class="subtitle">
				The Pacific Education Network’s team are core contributors to the cause of free, accessible, and personalized
				tutoring. Without the hard work and dedication from them, our society would not be the same as it is today.
			</p></Word
		>
	</div>
	<div class="spacer"></div>
	<section class="name-section">
		<h2>Executive Board</h2>
		<p>
			Meet the executives who keep our society thriving! From providing administrative services, scheduling courses,
			marketing, and ensuring student satisfaction, these are the people who have shaped the Pacific Education
			Network's success.
		</p>
		<div class="board-grid-top">
			{
				boardTop.map(x => (
					<div class="grid-item board-top-item">
						<div class="portrait-image">
							<Image src={imageFor(x.image)} alt={x.name} inferSize />
						</div>
						<h3 class="name">{x.name}</h3>
						<p class="title">{x.title}</p>
					</div>
				))
			}
		</div>
		<div class="board-grid">
			{
				board.map(x => (
					<div class="grid-item board-item">
						<div class="portrait-image">
							<Image src={imageFor(x.image)} alt={x.name} inferSize  />
						</div>
						<h3 class="name">{x.name}</h3>
						<p class="title">{x.title}</p>
					</div>
				))
			}
		</div>
	</section>
	<div class="spacer"></div>
	<section class="name-section">
		<h2>Tutors</h2>
		<p>
			Meet our hardworking tutors who bring Pacific Education Network's free teaching to life! From publishing resources,
			ensuring consistency, creating opportunities for growth, and fostering genuine connection, these hardworking
			individuals are the reason why the Pacific Education Network is able to empower individuals students in their
			pursuit of knowledge.
		</p>
		{tutors.map(group => (
			<div class="tutor-group">
				<h3 class="subject-heading">{group.subject}</h3>
				<div class="tutor-grid">
					{group.members.map(x => (
						<div class="grid-item tutor-item">
							<div class="portrait-image">
								<Image src={imageFor(x.image)} alt={x.name} inferSize />
							</div>
							<h3 class="name">{x.name}</h3>
							<p class="title">{x.title}</p>
						</div>
					))}
				</div>
			</div>
		))}
	</section>

	<style>
		.tutor-group {
			margin-top: var(--space-xl);
		}

		.subject-heading {
			text-align: center;
			font-family: var(--font-glacial);
			font-size: var(--step-1);
			margin-bottom: 0em;
			font-weight: 600;
		}

		.spacer {
			height: 6em;
		}
		.title {
			margin-top: 0.5em;
			font-family: var(--font-montserrat);
			align-items: center;
			text-align: left;
			display: flex;
			flex-direction: column;
			h1 {
				font-size: 2rem;
			}
			.subtitle {
				font-family: var(--font-glacial);
				max-width: 50em;
			}
		}
		.name-section {
			h2 {
				text-align: center;
				font-family: var(--font-montserrat);
				font-size: 1.6em;
				margin-bottom: 0.5em;
			}
			p {
				text-align: left;
			}
			> p {
				max-width: 53em;
				margin: 0 auto;
			}
		}
		
		.board-grid-top, .board-grid, .tutor-grid {
			display: grid;
			margin: 0 auto;
			padding-top: 2em;
			gap: 3em;
			width: fit-content;
			grid-template-columns: repeat(1, 1fr);
		}

		@media (width < 768px) {
			.board-grid-top, .board-grid, .tutor-grid {
				grid-template-columns: repeat(1, 1fr);
			}
		}

		@media (768px <= width < 1024px) {
			.board-grid, .tutor-grid {
				grid-template-columns: repeat(2, 1fr);
				max-width: 80em;
			}
			.board-grid-top {
				grid-template-columns: repeat(1, 1fr);
				max-width: 80em;
			}
		}

		@media (1024px <= width) {
			.tutor-grid {
				grid-template-columns: repeat(3, 1fr);
				max-width: 80em;
			}
			.board-grid {
				grid-template-columns: repeat(4, 1fr);
			}
			.board-grid-top {
				grid-template-columns: repeat(2, 1fr);
				max-width: 80em;
			}
		}

		.grid-item {
			text-align: center;
			line-height: 1.1;
			.portrait-image {
				aspect-ratio: 16 / 20;
				background-color: black;
				border: 2px white solid;
				border-radius: 0.8em;
				margin-bottom: 0.5em;
				img {
					display: block;
					width: 100%;
					height: 100%;
					border-radius: 0.8em;
					object-fit: cover;
					object-position: center center;
				}
			}
			.name {
				margin: 0;
				font-size: 1em;
				font-family: var(--font-montserrat);
			}
			.title {
				margin: 0;
				font-family: var(--font-glacial);
			}
		}
		.board-top-item {
			.portrait-image {
				aspect-ratio: 1 / 1;
			}
			width: 13em;
		}
		.board-item {
			width: 10em;
		}
		.tutor-item {
			width: 11em;
		}
	</style>
</Layout>
