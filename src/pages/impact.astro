---
import Word from "../components/Word.astro";
import Layout from "../layouts/Layout.astro";
import { Picture } from "astro:assets";
import fundraiser from "../assets/img/impact/fundraiser.jpg";
import LinkButton from "../components/LinkButton.astro";
import { Image } from 'astro:assets';

const icons = import.meta.glob<{default: ImageMetadata}>('../assets/icons/resources/*.svg', { eager: true });
const imageFor = (name: string) => icons[`../assets/icons/resources/${name}-light.svg`].default;
---

<Layout title="PEN | Impact">
	<h1 class="title">
		<Word>Our <em>Impact</em></Word>
	</h1>
	<p class="subtitle">
		<Word delay={1}
			>The Pacific Education Network creates real and measureable impact through direct support of students, free resource
			publication, and community fundraising.</Word
		>
	</p>
	<section class="content-grid">
		<div class="description">
			<h2><em>Tutoring & Mentorship</em></h2>
			<p>
				We run tutoring sessions led by our student tutor team to help learners improve confidence, skills, and grades.
				Sessions focus on clear explanations, study strategies, and consistent support, especially for students who
				don’t have access to paid tutoring.
			</p>
			<LinkButton href="/apply">Join & Apply</LinkButton>
		</div>
		<div class="icon-container">
			<p>Over $500,000 CAD saved, compared to a rate of $50/hour</p>
			<Image src={imageFor("money-wavy")} fit="contain" alt="" class="icon-image blue" />
		</div>
		<div class="icon-container">
			<p>1-1 Tutor Sessions with over 20 students</p>
			<Image src={imageFor("student")} alt="" class="icon-image" />
		</div>
		<div class="description">
			<h2><em>Published Resources</em></h2>
			<p>
				We publish free resources including notes, guides, practice questions, and study plans so students can learn on
				their own time. These materials are designed to be simple, helpful, and easy to use.
			</p>
			<LinkButton href="/resources">Published Resources</LinkButton>
		</div>
		<div class="icon-container">
			<p>10 schools across 4 countries engaged</p>
			<Image src={imageFor("globe")} alt=""  class="icon-image" />
		</div>
		<div class="icon-container">
			<p>9 Pieces of Study Material</p>
			<Image src={imageFor("books")} alt="" class="icon-image blue" />
		</div>
		<div class="description">
			<h2><em>Fundraisers that give back</em></h2>
			<p>
				Our fundraisers help us continue what we do best. Every fundraiser increases our reach and spreads awareness,
				and with the community's support, we impact more students, host more events, and maintain our devotion to 100%
				free education. The message behind the public’s empowerment is simple: educational support should be free and
				accessible to everyone.
			</p>
		</div>
		<div class="large-image-container">
			<div class="large-image">
				<Picture src={fundraiser} alt="Fundraiser event at Metrotown" />
			</div>
			<p class="caption">Fundraiser event at Metrotown. 2025-01-02</p>
		</div>
	</section>
</Layout>

<style>
	h2 {
		margin-top: 0;
	}
	.title {
		font-size: 4rem;
		margin-top: 0.5em;
		margin-bottom: 0;
		font-family: var(--font-montserrat);
		text-align: center;
	}
	.subtitle {
		margin: 0 auto;
		text-align: center;
		max-width: 50em;
	}
	.content-grid {
		display: grid;
		grid-template-columns: 2fr 1fr 1fr;
		row-gap: 4em;
		column-gap: 2em;
		margin: 3em auto 0;
		padding: 0 2em;
		max-width: 70rem;
	}
	.icon-container {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		justify-content: space-between;
		gap: 1em;
		p {
			margin: 0 auto;
		}
	}
	.icon-image {
		width: 10em;
		height: 10em;
		background-color: rgb(26, 104, 239);
		border-radius: 50%;
		object-fit: contain;
		filter: invert(1) hue-rotate(180deg);
	}
	.blue {
		background-color: cornflowerblue;
	}
	.large-image-container {
		grid-column: span 2;
		text-align: center;
		display: flex;
		flex-direction: column;
		align-items: center;
	}
	.large-image {
		width: 24em;
		img {
			width: 100%;
			height: auto;
		}
	}
	.caption {
		font-style: italic;
		font-size: 0.95em;
	}

	@media (max-width: 768px) {
		.content-grid {
			grid-template-columns: 1fr;
			padding: 0;
		}
		.icon-container {
			flex-direction: row;
			text-align: left;
			align-items: center;
		}
		.icon-image {
			width: 4em;
			height: 4em;
			flex-shrink: 0;
		}
		.large-image-container {
			grid-column: span 1;
		}
		.large-image {
			width: 100%;
		}
	}
</style>
