---
import { Font } from "astro:assets";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

const { title } = Astro.props;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{title}</title>
		<Font cssVariable="--font-glacial" />
		<Font cssVariable="--font-montserrat" />
	</head>
	<body>
		<article>
			<Nav />
			<slot />
		</article>
		<div class="separator"></div>
		<Footer />
	</body>
</html>

<style>
	/* @link https://utopia.fyi/type/calculator?c=360,18,1.2,1240,20,1.25,5,2,&s=0.75|0.5|0.25,1.5|2|3|4|6,s-l&g=s,l,xl,12 */

	:root {
		--fluid-10-36: clamp(0.625rem, 0.0625rem + 2.5vw, 2rem);

		--step--2: clamp(0.7813rem, 0.7736rem + 0.0341vw, 0.8rem);
		--step--1: clamp(0.9375rem, 0.9119rem + 0.1136vw, 1rem);
		--step-0: clamp(1.125rem, 1.0739rem + 0.2273vw, 1.25rem);
		--step-1: clamp(1.35rem, 1.2631rem + 0.3864vw, 1.5625rem);
		--step-2: clamp(1.62rem, 1.4837rem + 0.6057vw, 1.9531rem);
		--step-3: clamp(1.944rem, 1.7405rem + 0.9044vw, 2.4414rem);
		--step-4: clamp(2.3328rem, 2.0387rem + 1.3072vw, 3.0518rem);
		--step-5: clamp(2.7994rem, 2.384rem + 1.8461vw, 3.8147rem);

		--grid-max-width: 77.50rem;
		--grid-gutter: var(--space-s-l, clamp(1.125rem, 0.5625rem + 2.5vw, 2.5rem));
		--grid-columns: 12;
		
		--fluid-4-20: clamp(0.25rem, -0.1591rem + 1.8182vw, 1.25rem);
		--space-3xs: clamp(0.3125rem, 0.3125rem + 0vw, 0.3125rem);
		--space-2xs: clamp(0.5625rem, 0.5369rem + 0.1136vw, 0.625rem);
		--space-xs: clamp(0.875rem, 0.8494rem + 0.1136vw, 0.9375rem);
		--space-s: clamp(1.125rem, 1.0739rem + 0.2273vw, 1.25rem);
		--space-m: clamp(1.6875rem, 1.6108rem + 0.3409vw, 1.875rem);
		--space-l: clamp(2.25rem, 2.1477rem + 0.4545vw, 2.5rem);
		--space-xl: clamp(3.375rem, 3.2216rem + 0.6818vw, 3.75rem);
		--space-2xl: clamp(4.5rem, 4.2955rem + 0.9091vw, 5rem);
		--space-3xl: clamp(6.75rem, 6.4432rem + 1.3636vw, 7.5rem);

		--padding: clamp(0rem, 1.6108rem + 0.3409vw, 1.875rem);

		--space-xxl: clamp(0em, 25vw, 20vw);
		--space-boxxxl: clamp(1em, 15vw, 20vw);
		--space-boxxl: clamp(1em, 8vw, 8vw);

		/* One-up pairs */
		--space-3xs-2xs: clamp(0.3125rem, 0.1847rem + 0.5682vw, 0.625rem);
		--space-2xs-xs: clamp(0.5625rem, 0.4091rem + 0.6818vw, 0.9375rem);
		--space-xs-s: clamp(0.875rem, 0.7216rem + 0.6818vw, 1.25rem);
		--space-s-m: clamp(1.125rem, 0.8182rem + 1.3636vw, 1.875rem);
		--space-m-l: clamp(1.6875rem, 1.3551rem + 1.4773vw, 2.5rem);
		--space-l-xl: clamp(2.25rem, 1.6364rem + 2.7273vw, 3.75rem);
		--space-xl-2xl: clamp(3.375rem, 2.7102rem + 2.9545vw, 5rem);
		--space-2xl-3xl: clamp(4.5rem, 3.2727rem + 5.4545vw, 7.5rem);

		/* Custom pairs */
		--space-s-l: clamp(1.125rem, 0.5625rem + 2.5vw, 2.5rem);
	}

	.separator {
		flex-grow: 1;
	}
	body {
		font-family: var(--font-glacial);
		background-color: #060d49;
		background-image: radial-gradient(#001b3d, #060d49, #000000);
		min-height: 100dvh;
		color: #ffffff;
		font-size: var(--step-0);
		margin: 0;
		display: flex;
		flex-direction: column;
	}
	article {
		margin: var(--space-s);
	}
</style>
<style is:global>
	a:hover {
		text-decoration: underline;
	}
	:root {
		line-height: 1.5;
	}
	* {
		box-sizing: border-box;
	}
	em {
		font-style: unset;
		background-image: linear-gradient(90deg, #477cdf, #58e2d4);
		background-color: #477cdf;
		color: transparent;
		background-clip: text;
		-webkit-background-clip: text;
	}
	p {
		margin: 0;
	}
</style>
